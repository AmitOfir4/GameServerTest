{
  "name": "fish-of-fortune-test-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Interview-ready Node.js backend API with automation test suites",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:db": "tsx --env-file=.env src/scripts/run-db-api.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --selectProjects unit integration e2e contract --coverage",
    "test:all": "jest --coverage",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "jest --selectProjects e2e",
    "test:contract": "jest --selectProjects contract",
    "test:db": "jest --selectProjects db",
    "test:smoke": "jest --selectProjects smoke",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.24.0",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.3",
    "ajv": "^8.17.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.24.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
