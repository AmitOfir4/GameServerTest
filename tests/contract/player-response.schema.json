{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "username", "level", "coins", "inventory"],
  "properties": {
    "id": { "type": "string" },
    "username": { "type": "string" },
    "level": { "type": "integer" },
    "coins": { "type": "integer" },
    "inventory": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    }
  },
  "additionalProperties": false
}
